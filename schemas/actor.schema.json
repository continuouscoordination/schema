{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://continuouscoordination.org/schema/actor.schema.json",
  "title": "Actor",
  "description": "A participant in one or more coordination loops. An actor can be a person or an agent.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for this actor."
    },
    "actor_type": {
      "type": "string",
      "enum": ["person", "agent"],
      "description": "The type of actor: a human person or an automated agent."
    },
    "name": {
      "type": "string",
      "description": "Display name."
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "Email address."
    },
    "role": {
      "type": "string",
      "description": "Job title or role within the organization."
    },
    "timezone": {
      "type": "string",
      "description": "IANA timezone identifier (e.g. America/New_York)."
    }
  },
  "required": ["id", "actor_type", "name"]
}
